# =============================================================================
# Plantilla de variables de entorno — Frontend (Vue CLI)
# =============================================================================
#
# Uso:
#   - Desarrollo: copiar secciones relevantes a .env.development
#   - Producción: copiar secciones relevantes a .env.production
#   - Overrides locales (no commitear): frontend/.env.local
#
# Carga por entorno:
#   - npm run serve  → .env.development (+ .env.local si existe)
#   - npm run build  → .env.production (+ .env.local si existe)
#
# Despliegue en VPS:
#   1. Editar .env.production con los datos del cliente/negocio.
#   2. Ejecutar npm run build desde la raíz del proyecto.
#   3. Publicar la carpeta frontend/dist/ generada.
#   Si cambias .env después del build, debes volver a compilar para ver los cambios.
#
# Nota: solo las variables con prefijo VUE_APP_ están disponibles en el frontend.
# Los datos de empresa (NIT, dirección, etc.) son públicos en el ticket impreso.
# =============================================================================

# --- Desarrollo (backend / puertos locales) ---
VUE_APP_DEV_BACKEND_HOST=localhost
VUE_APP_DEV_BACKEND_PORT=3000
VUE_APP_DEV_FRONTEND_PORT=5173

# --- WebSocket / PeerJS ---
VUE_APP_WS_PATH=/pb-realtime-ws
VUE_APP_PEER_PATH=/peerjs
VUE_APP_PEER_KEY=peerjs
# VUE_APP_PEER_URL=https://tu-dominio.ejemplo.com

# --- API / uploads (opcional en dev) ---
# VUE_APP_API_URL=http://localhost:3000/api
# VUE_APP_UPLOADS_BASE_URL=http://localhost:3000
# VUE_APP_SOCKET_URL=

# --- Bridge local (PC caja/cocina, Windows) ---
# Cajon: frontend/src/services/cashDrawerBridge.js
# VUE_APP_CASH_DRAWER_BRIDGE_URL=http://127.0.0.1:4545/api/abrir-cajon
# Impresion silenciosa comanda cocina: frontend/src/services/printBridgeService.js
# VUE_APP_PRINT_BRIDGE_URL=http://127.0.0.1:4545/api/imprimir-ticket

# --- Datos fiscales / empresa (tickets, precuenta, Bluetooth) ---
# Consumidos por frontend/src/config/businessInfo.js
VUE_APP_BUSINESS_RAZON_SOCIAL=Mi Empresa S.A.S.
VUE_APP_BUSINESS_TIPO_DOCUMENTO=NIT
VUE_APP_BUSINESS_NUMERO_DOCUMENTO=900000000-0
VUE_APP_BUSINESS_DIRECCION=Calle 00 # 0-00
VUE_APP_BUSINESS_MUNICIPIO=Manizales
VUE_APP_BUSINESS_DEPARTAMENTO=Caldas
VUE_APP_BUSINESS_REGIMEN=Responsable de IVA
VUE_APP_BUSINESS_ACTIVIDAD_ECONOMICA=Actividad economica del negocio
VUE_APP_BUSINESS_TELEFONO=+57 300 000 0000
VUE_APP_BUSINESS_EMAIL=contacto@miempresa.com

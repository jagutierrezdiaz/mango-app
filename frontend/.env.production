# Mantener lo esencial para el build frontend:
VUE_APP_WS_PATH=/pb-realtime-ws
VUE_APP_PEER_PATH=/peerjs
VUE_APP_PEER_KEY=peerjs

# Opcional explícito (no necesario si solo despliegas en mango):
# VUE_APP_PEER_URL=https://mango.hazlosoftware.com

# --- Datos fiscales / empresa (tickets, precuenta, Bluetooth) ---

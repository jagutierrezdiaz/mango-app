VUE_APP_BUSINESS_TIPO_DOCUMENTO=NIT
VUE_APP_BUSINESS_NUMERO_DOCUMENTO=900000000-0
VUE_APP_BUSINESS_DIRECCION=Calle 00 # 0-00
VUE_APP_BUSINESS_MUNICIPIO=Manizales
VUE_APP_BUSINESS_DEPARTAMENTO=Caldas
VUE_APP_BUSINESS_REGIMEN=Responsable de IVA
VUE_APP_BUSINESS_ACTIVIDAD_ECONOMICA=Actividad economica del negocio
